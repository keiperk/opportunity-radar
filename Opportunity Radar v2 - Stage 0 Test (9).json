      "parameters": {
        "jsCode": "function canonicalizeCompany(name) {\n  if (!name) return \"\";\n\n  return name\n    .toString()\n    .toLowerCase()\n    .normalize(\"NFKD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/\\b(inc|llc|ltd|corp|co|ai|labs?)\\b\\.?/g, \"\")\n    .replace(/[^a-z0-9]/g, \"\")\n    .trim();\n}\n\nreturn $input.all().map((item) => {\n  return {\n    json: {\n      ...item.json,\n      company_canonical: canonicalizeCompany(item.json.company_display)\n    }\n  };\n});"
      },
