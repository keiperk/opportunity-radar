      "id": "e57471dd-60ba-4d7b-9f37-f5fa7f78af47",
      "name": "Normalize LinkedIn Jobs"
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst grouped = {};\n\nfor (const item of allItems) {\n  const d = item.json;\n  const key = d.company_canonical;\n  if (!key) continue;\n\n  if (!grouped[key]) {\n    grouped[key] = {\n      run_id: d.run_id,\n      run_ts: d.run_ts,\n      company_canonical: d.company_canonical,\n      company_display: d.company_display,\n      discovery_source: d.discovery_source,\n      news_signals: 0,\n      reddit_signals: 0,\n      linkedin_signals: 0,\n      github_signals: 0,\n      hn_signals: 0\n    };\n  }\n\n  const count = Number(d.count) || 0;\n\n  if (d.source === 'news') grouped[key].news_signals += count;\n  else if (d.source === 'reddit') grouped[key].reddit_signals += count;\n  else if (d.source === 'linkedin_jobs') grouped[key].linkedin_signals += count;\n  else if (d.source === 'github') grouped[key].github_signals += count;\n  else if (d.source === 'hn') grouped[key].hn_signals += count;\n}\n\nreturn Object.values(grouped).map(row => ({ json: row }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3104,
        208
      ],
      "id": "5b56c875-baab-4e2e-b07d-7e73a58c91ac",
      "name": "Aggregate Signals By Company"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $json;\n\nconst weights = { news: 0.25, reddit: 0.2, linkedin: 0.25, github: 0.15, hn: 0.15 };\nconst caps = { news: 10, reddit: 10, linkedin: 15, github: 30, hn: 10 };\n\nconst newsNorm = Math.min(d.news_signals || 0, caps.news) / caps.news;\nconst redditNorm = Math.min(d.reddit_signals || 0, caps.reddit) / caps.reddit;\nconst linkedinNorm = Math.min(d.linkedin_signals || 0, caps.linkedin) / caps.linkedin;\nconst githubNorm = Math.min(d.github_signals || 0, caps.github) / caps.github;\nconst hnNorm = Math.min(d.hn_signals || 0, caps.hn) / caps.hn;\n\nconst opportunity_index =\n  newsNorm * weights.news +\n  redditNorm * weights.reddit +\n  linkedinNorm * weights.linkedin +\n  githubNorm * weights.github +\n  hnNorm * weights.hn;\n\nreturn {\n  json: {\n    ...d,\n    opportunity_index: Math.round(opportunity_index * 100) / 100\n  }\n};"
      },
