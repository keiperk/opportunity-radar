    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const upstream = $(\"Canonicalize Companies\").item.json;\n\nconst organicResults = Array.isArray($json.organic) ? $json.organic : [];\n\nreturn {\n  json: {\n    run_id: upstream.run_id,\n    run_ts: upstream.run_ts,\n    company_canonical: upstream.company_canonical,\n    company_display: upstream.company_display,\n    discovery_source: upstream.discovery_source,\n    source: \"linkedin_jobs\",\n    count: organicResults.length\n  }\n};"
