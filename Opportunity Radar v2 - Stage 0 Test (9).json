            {
              "content": "==Extract company names from the following search results:\n\n{{ JSON.stringify($json.news.map(r => ({ title: r.title, snippet: r.snippet }))) }}"
            }
          ]
        },
        "simplify": false,
        "builtInTools": {},
        "options": {
          "instructions": "You are a data extraction assistant. You will be given a list of news article titles and snippets. Extract every distinct company name mentioned that appears to be a startup, private company, or business raising funding, launching a product, or hiring.\n\nDo not include investors, VC firms, universities, government agencies, or generic terms like \"the company\" without a proper name.\n\nExtract every company mentioned, even if uncertain. Only return an empty array if no company names appear anywhere in the text.\n\nReturn ONLY valid JSON, no markdown, no commentary, in this exact format:\n{\"companies\": [{\"company_name\": \"string\", \"source_snippet\": \"string\"}]}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
