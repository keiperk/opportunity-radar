    {
      "parameters": {
        "jsCode": "const allCompanies = [];\n\nfor (const item of $input.all()) {\n  const j = item.json;\n  let raw;\n\n  if (Array.isArray(j.output)) {\n    const msg = j.output.find(o => o.type === 'message');\n    raw = msg?.content?.[0]?.text;\n  }\n\n  if (!raw) continue;\n\n  let parsed;\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    continue;\n  }\n\n  const companies = parsed.companies || [];\n  for (const c of companies) {\n    if (!c.company_name) continue;\n    allCompanies.push({\n      json: {\n        company_display: c.company_name,\n        source_snippet: c.source_snippet || ''\n      }\n    });\n  }\n}\n\nreturn allCompanies;"
      },
